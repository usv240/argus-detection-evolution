# Copy to .env and fill in REAL values. Never commit .env.
# If any required value is missing, the backend fails loudly (no mock data) — by design.

# --- Splunk instance (Splunk SDK fallback search path) ---
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_SCHEME=https
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=
SPLUNK_VERIFY=false
SPLUNK_INDEX=botsv3
SPLUNK_SANDBOX_INDEX=argus_sandbox

# HEC write path for synthetic adversarial variants (Red agent). Enable HEC + create a token:
#   splunk http-event-collector enable; splunk http-event-collector create argus -index argus_sandbox
SPLUNK_HEC_URL=https://localhost:8088/services/collector/event
SPLUNK_HEC_TOKEN=

# --- Splunk MCP Server (primary search path for agents) ---
# Official Splunk MCP Server (Splunkbase app id 7931): hosted in Splunk at the mgmt port.
# Endpoint pattern: https://<host>:8089/services/mcp  (HTTP/SSE, Bearer auth, respects RBAC).
# Create a Splunk auth token (Settings > Tokens) and put it in SPLUNK_MCP_TOKEN.
SPLUNK_MCP_URL=https://localhost:8089/services/mcp
SPLUNK_MCP_TOKEN=

# --- Search provider selection: "mcp" (primary) or "sdk" (fallback). ---
SEARCH_PROVIDER=mcp

# --- Model layer for the Scorer (decided by SETUP.md Step 6 spike) ---
# "hosted" = Splunk hosted model · "local" = a real local/3p model, labeled as such in the UI.
# Never set this to a mode that fabricates a score.
SCORER_BACKEND=
SCORER_HOSTED_ENDPOINT=
SCORER_HOSTED_MODEL=

# --- Reasoning LLM for agent planning/SPL generation/explanations (tiered for cost) ---
ANTHROPIC_API_KEY=
# Primary agent model. Sonnet = best cost/quality balance; bump to claude-opus-4-8 only if needed.
ANTHROPIC_MODEL=claude-sonnet-4-6
# Fast/cheap tier for narration + simple steps.
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
